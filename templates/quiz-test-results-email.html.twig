<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ 'Результаты теста'|t }}</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f5f5f5; font-family: Arial, Helvetica, sans-serif; font-size: 14px; color: #333; line-height: 1.5;">

  <!-- Outer wrapper -->
  <table width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f5f5f5; padding: 24px 0;">
    <tr>
      <td align="center">

        <!-- Inner card -->
        <table width="640" cellpadding="0" cellspacing="0" border="0" style="background-color: #ffffff; border: 1px solid #e0e0e0; border-radius: 6px; overflow: hidden;">

          <!-- Header bar -->
          <tr>
            <td style="background-color: #c0392b; padding: 16px 24px;">
              <h1 style="margin: 0; padding: 0; font-size: 18px; font-weight: 700; color: #ffffff; font-family: Arial, Helvetica, sans-serif;">{{ 'Результаты тестирования'|t }}</h1>
            </td>
          </tr>

          <!-- Meta info -->
          <tr>
            <td style="padding: 20px 24px 0 24px;">
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="font-size: 13px; color: #555;">
                <tr>
                  <td style="padding: 4px 0;">
                    <strong style="color: #333;">{{ 'Тест:'|t }}</strong> {{ test_label }}
                  </td>
                </tr>
                <tr>
                  <td style="padding: 4px 0;">
                    <strong style="color: #333;">{{ 'Пользователь:'|t }}</strong> {{ user_display_name }}
                  </td>
                </tr>
                {% if full_name %}
                <tr>
                  <td style="padding: 4px 0;">
                    <strong style="color: #333;">{{ 'ФИО:'|t }}</strong> {{ full_name }}
                  </td>
                </tr>
                {% endif %}
                {% if has_score %}
                <tr>
                  <td style="padding: 4px 0; font-size: 14px; font-weight: 700; color: #c0392b;">
                    {% set summary_text = 'Итого: @correct из @total — @score%'|t({'@correct': correct, '@total': total, '@score': score_percent}) %}
                    {{ summary_text }}
                    {% if open_questions %}<span style="color:#555; font-weight:400;"> ({{ 'плюс @count открытых вопросов'|t({'@count': open_questions|length}) }})</span>{% endif %}
                  </td>
                </tr>
                {% endif %}
                <tr>
                  <td style="padding: 4px 0;">
                    <strong style="color: #333;">{{ 'Дата:'|t }}</strong> {{ date }}
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <!-- Separator -->
          <tr>
            <td style="padding: 12px 24px 0 24px;">
              <hr style="border: none; border-top: 1px solid #e0e0e0; margin: 0;" />
            </td>
          </tr>

          <!-- Part 1: Multiple-choice questions -->
          {% if questions %}
          <tr>
            <td style="padding: 16px 24px 0 24px;">
              <h2 style="margin: 0 0 12px 0; padding: 0; font-size: 15px; font-weight: 700; color: #c0392b; font-family: Arial, Helvetica, sans-serif;">{{ 'Часть 1. Тестирование'|t }}</h2>
              {% for question in questions %}
              <!-- Question block -->
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 16px;">
                <tr>
                  <td style="padding-bottom: 8px;">
                    <span style="font-size: 14px; font-weight: 700; color: #222;">{{ loop.index }}. {{ question.question_text }}</span>
                  </td>
                </tr>
                <tr>
                  <td style="padding-left: 20px;">
                    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="font-size: 13px;">
                      <tr>
                        <td style="padding: 2px 0; color: #555;">
                          &bull; {{ 'Ответ пользователя:'|t }} {{ question.user_answer }}
                        </td>
                      </tr>
                      <tr>
                        <td style="padding: 2px 0; color: #555;">
                          &bull; {{ 'Верный ответ:'|t }} {{ question.correct_answer }}
                        </td>
                      </tr>
                      <tr>
                        <td style="padding: 2px 0;">
                          {% if question.is_correct %}
                            <span style="color: #27ae60; font-weight: 600;">&bull; {{ 'Результат: верно'|t }}</span>
                          {% else %}
                            <span style="color: #c0392b; font-weight: 600;">&bull; {{ 'Результат: неверно'|t }}</span>
                          {% endif %}
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
              {% if not loop.last %}
              <hr style="border: none; border-top: 1px solid #eeeeee; margin: 0 0 16px 0;" />
              {% endif %}
              {% endfor %}
            </td>
          </tr>
          {% endif %}

          <!-- Part 2: Open questions -->
          {% if open_questions %}
          <tr>
            <td style="padding: {% if questions %}24px{% else %}16px{% endif %} 24px 0 24px; border-top: {% if questions %}1px solid #e0e0e0{% else %}0{% endif %};">
              <h2 style="margin: 0 0 12px 0; padding: 0; font-size: 15px; font-weight: 700; color: #2c3e50; font-family: Arial, Helvetica, sans-serif;">{{ 'Часть 2. Открытые вопросы'|t }}</h2>
              {% for oq in open_questions %}
              <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 16px;">
                <tr>
                  <td style="padding-bottom: 4px;">
                    <span style="font-size: 14px; font-weight: 700; color: #222;">{{ loop.index }}. {{ oq.question_text }}</span>
                  </td>
                </tr>
                <tr>
                  <td style="padding-left: 20px; font-size: 13px; color: #555;">
                    &bull; {{ 'Ответ:'|t }}
                    {% if oq.user_answer %}{{ oq.user_answer }}{% else %}<span style="color:#999;">{{ 'нет ответа'|t }}</span>{% endif %}
                  </td>
                </tr>
              </table>
              {% endfor %}
            </td>
          </tr>
          {% endif %}

          <!-- Separator -->
          <tr>
            <td style="padding: 0 24px 8px 24px;">
              <hr style="border: none; border-top: 1px solid #e0e0e0; margin: 0;" />
            </td>
          </tr>

          <!-- Summary -->
          <tr>
            <td style="padding: 8px 24px 20px 24px; font-size: 15px; font-weight: 700; color: #222;">
              {% if has_score %}
                {% set summary_text = 'Итого: @correct из @total — @score%'|t({'@correct': correct, '@total': total, '@score': score_percent}) %}
                {{ summary_text }}{% if open_questions %} <span style="color:#555; font-weight:400;">({{ 'плюс @count открытых вопросов'|t({'@count': open_questions|length}) }})</span>{% endif %}
              {% else %}
                {{ 'Открытых вопросов: @count (без автопроверки)'|t({'@count': open_questions|length}) }}
              {% endif %}
            </td>
          </tr>

        </table>
        <!-- /Inner card -->

      </td>
    </tr>
  </table>
  <!-- /Outer wrapper -->

</body>
</html>
